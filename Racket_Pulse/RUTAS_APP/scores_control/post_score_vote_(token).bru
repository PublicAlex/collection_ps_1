meta {
  name: post score vote (token)
  type: http
}

post {
  url: {{host}}/match_score_proposals/vote
  body: json
  auth: inherit
}

body:json {
  {
    "user_id": 1,
    "match_id": 104,  // Por defecto cuando solo se envía un voto usando el match_id, usará como referencia por defecto la propuesta más votada
    "approved": true
    //"proposal_id": 99   // campo opcional 
  }
}
