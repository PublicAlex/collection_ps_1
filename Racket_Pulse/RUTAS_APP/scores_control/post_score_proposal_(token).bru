meta {
  name: post score proposal (token)
  type: http
}

post {
  url: {{host}}/match_score_proposals
  body: json
  auth: inherit
}

body:json {
  {
    "match_id": 170,   // identificador del match
    "user_id": 1,   // identificador del user que registra el score propuesto
    "team1_scores": [
      "9",
      "1",
      "8"
    ],
    "team2_scores": [
      "3",
      "2",
      "4"
    ]
  }
}
