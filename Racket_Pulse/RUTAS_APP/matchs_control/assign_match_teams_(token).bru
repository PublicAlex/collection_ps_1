meta {
  name: assign match teams (token)
  type: http
}

post {
  url: {{host}}/match_teams
  body: json
  auth: inherit
}

body:json {
{
  "match_id": 396, // match de ejemplo previamente creado con ID #17
  "user_id": 1,   // usuario de ejemplo previamente creado con ID #1
  "team": "team1",
  "position": "left"
}
}
