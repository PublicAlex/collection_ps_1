meta {
  name: Crear Club No Oficial
  type: http
}

post {
  url: {{host}}/club_users/quick-setup
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "club_name": "Los Amigos 3",
    "location": "Carrer Segurana, Xàtiva, València, España",
    "location_coordinate": "38.9881694,-0.5156206"
  }
}
