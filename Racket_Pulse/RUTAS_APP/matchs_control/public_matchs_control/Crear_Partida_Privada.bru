meta {
  name: Crear Partida Privada
  type: http
}

post {
  url: {{host}}/matches
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "court_id": 158,
    "date": "2026-03-18",
    "start_time": "18:00",
    "end_time": "19:00",
    "type": "private",
    "payment_required": false // tipo de reserva cash quemado
  }
}
