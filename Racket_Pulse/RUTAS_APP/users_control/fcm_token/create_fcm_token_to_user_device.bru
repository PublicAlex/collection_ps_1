meta {
  name: create fcm token to user device
  type: http
}

post {
  url: {{host}}/device_tokens/users/1
  body: json
  auth: inherit
}

body:json {
{
  "token": "dGVzdF90b2tlbl9mY2sdfwerXBsZQd12", // device token
  "deviceType": "android",
  "deviceName": "iPhone 15 Pro", // opcional**
  "appVersion": "1.2.3",// opcional 
  "osVersion": "iOS 17.0"// opcional 
}
}
