meta {
  name: create match payment
  type: http
}

post {
  url: {{host}}/fiuu/payments
  body: json
  auth: inherit
}

body:json {
  {
    "userId": 1,
    "clubId": 1,
    "amount": 35.5,
    "currency": "MYR",
    "platformFeePercentage": 10,
    "matchId": 459,
    "description": "Court reservation payment",
    "paymentChannel": "credit",
    "customerName": "John Doe",
    "customerEmail": "john@example.com",
    "customerPhone": "+60123456789"
  }
}
