meta {
  name: create match payment
  type: http
}

post {
  url: {{host}}/payments
  body: json
  auth: inherit
}

body:json {
  {
    "user_id": 1,    // asignamos un pago pendiente para el user con id
    "match_id": 223,  // referenciando el match id
    "club_id": 1,  // y tambien referenciando al club
    "success_url": "https://dev.api.racketpulse.com/payments/confirm",
    "cancel_url": "https://dev.api.racketpulse.com/payments/cancel"
  }
}
