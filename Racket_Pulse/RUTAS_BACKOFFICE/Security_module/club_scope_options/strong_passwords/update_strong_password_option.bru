meta {
  name: update strong password option
  type: http
}

patch {
  url: {{host}}/club_users/1/security-settings/strong-password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "requireStrongPassword": true,  // or false
    "clubId": 1  //   enviar para propagar a todo el club
  }
}
