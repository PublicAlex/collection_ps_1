meta {
  name: view case 2: admin view (filter by date/status)
  type: http
}

get {
  url: {{host}}/admin/scheduled-payouts?status=pending_review&startDate=2024-01-01T00:00:00.000Z&endDate=2026-12-31T23:59:59.000Z
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
  X-Secret-Key: 8ajk128nas8dho19-lkasdh9n1jnoas091nsd@-
}

script:post-response {
var jsonData = res.getBody();
if (jsonData.length > 0) {
    bru.setEnvVar("payoutId", jsonData[0].id);
}
}
