meta {
  name: Update Scores
  type: http
}

post {
  url: {{elohost}}/api/v1/scores/update
  body: json
  auth: inherit
}

headers {
  X-API-Key: 1234
}

body:json {
  {
    "scores_team_1": [0.72, 0.45],
    "scores_team_2": [0.61, 0.38],
    "outcome": [6, 3],
    "tournament_weight": 1.0,    // doble de peso que torneo amateurs
    "reliabilities_team_1": [0.80, 0.10],    // porcentaje de fiabilidad de cada jugador
    "reliabilities_team_2": [0.55, 0.00] 
  }
}
