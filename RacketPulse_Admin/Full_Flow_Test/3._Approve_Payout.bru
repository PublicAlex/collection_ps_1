meta {
  name: 3. Approve Payout
  type: http
}

patch {
  url: {{base_url}}/payer/payouts/{{payout_id}}/approve
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
{
    "notes": "Approved via Full Flow Test"
}
}

script:post-response {
test("Payout approved", function () {
    expect(res.getStatus()).to.equal(200);
    var jsonData = res.getBody();
    expect(jsonData.status).to.eql('approved');
});
}
