meta {
  name: Get Payouts - Filter by Date Range
  type: http
}

get {
  url: {{base_url}}/payer/payouts?status=pending_review&startDate=2024-01-01T00:00:00.000Z&endDate=2026-12-31T23:59:59.000Z
  body: none
  auth: inherit
}

script:post-response {
test("Status code is 200", function () {
    expect(res.getStatus()).to.equal(200);
});
}
