meta {
  name: Get Pending Payouts
  type: http
}

get {
  url: {{base_url}}/payer/payouts/pending
  body: none
  auth: inherit
}

script:post-response {
test("Status code is 200", function () {
    expect(res.getStatus()).to.equal(200);
});

test("All payouts are pending_review", function () {
    var jsonData = res.getBody();
    jsonData.forEach(function(payout) {
        expect(payout.status).to.eql('pending_review');
    });
});
}
