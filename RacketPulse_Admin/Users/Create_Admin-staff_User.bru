meta {
  name: Create Admin/staff User
  type: http
}

post {
  url: {{base_url}}/users
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
{
    "email": "newuser@example.com",
    "password": "password123",
    "name": "New",
    "lastname": "User",
    "role": "superadmin" // superadmin o payer
}
}
